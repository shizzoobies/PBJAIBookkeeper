{
  "name": "ai-bookkeeper",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "AI Bookkeeper (test build) — Cloudflare Worker API for QuickBooks Online sandbox",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply ai-bookkeeper --local",
    "db:migrate:remote": "wrangler d1 migrations apply ai-bookkeeper --remote",
    "tail": "wrangler tail"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "typescript": "^5.6.3",
    "wrangler": "^4.20.0"
  }
}
